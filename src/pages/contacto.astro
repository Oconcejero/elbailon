---
import Layout from "../layout/layout.astro";
---

<Layout title="Contacto | El Bailón">
  <section class="contacto-page">
    <div class="container">
      <h1>Contacta con nosotros</h1>
      <p class="subtitle">Reserva tu clase de prueba o cuéntanos tus dudas</p>

      <div class="contacto-grid">
        <div class="form-container">
          <form action="#" method="POST">
            <div class="input-group">
              <label for="nombre">Nombre</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                placeholder="Tu nombre..."
                required
              />
            </div>

            <div class="input-group">
              <label for="email">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="tu@email.com"
                required
              />
            </div>

            <div class="input-group">
              <label for="telefono">Teléfono</label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                placeholder="600 000 000"
              />
            </div>

            <div class="input-group">
              <label for="mensaje">Mensaje</label>
              <textarea
                id="mensaje"
                name="mensaje"
                rows="5"
                placeholder="¿En qué baile estás interesado?"></textarea>
            </div>

            <button type="submit" class="btn-enviar">Enviar Mensaje</button>
          </form>
        </div>

        <div class="info-container">
          <div class="google-maps-card">
            <div class="map-header">
              <div class="rating-badge">
                <span class="score">4.7</span>
                <span class="stars">★★★★★</span>
                <span class="count">(47 reseñas)</span>
              </div>
              <a
                href="https://maps.app.goo.gl/YourExactPlaceLink"
                target="_blank"
                class="btn-google"
              >
                Cómo llegar
              </a>
            </div>

            <div class="map-container">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3786.5550644934533!2d-3.6518106878911896!3d40.462694152720665!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd4228c514df39e3%3A0x66424bbc8bf223a1!2sEl%20Bail%C3%B3n!5e1!3m2!1ses!2ses!4v1773063800212!5m2!1ses!2ses"
                width="600"
                height="450"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
          </div>

          <div class="contact-details">
            <h3>Dónde estamos</h3>
            <p>📍 Carr. de Canillas, 46, posterior, Hortaleza, 28043 Madrid</p>
            <p>📞 917 21 93 62</p>
            <p>📞 640 36 68 30</p>
            <p>📧 escuelaelbailon@gmail.com</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
