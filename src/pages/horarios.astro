---

<Layout title="Horarios 2025-2026 | El Bailón">
  <section class="horarios-section">
    <div class="container">
      <h1>Horarios 2025 - 2026</h1>

      <h2>Horario de Tardes</h2>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Actividad</th>
              <th>Lunes</th>
              <th>Martes</th>
              <th>Miércoles</th>
              <th>Jueves</th>
              <th>Viernes</th>
              <th>Sábado</th>
            </tr>
          </thead>
          <tbody>
            {
              horariosTarde.map((h) => (
                <tr>
                  <td class="actividad-name">
                    <strong>{h.actividad}</strong>
                  </td>
                  <td data-label="Lunes">{h.lunes || "-"}</td>
                  <td data-label="Martes">{h.martes || "-"}</td>
                  <td data-label="Miércoles">{h.miercoles || "-"}</td>
                  <td data-label="Jueves">{h.jueves || "-"}</td>
                  <td data-label="Viernes">{h.viernes || "-"}</td>
                  <td data-label="Sábado">{h.sabado || "-"}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <h2 class="mt-4">Horario de Mañanas</h2>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Actividad</th>
              <th>Lunes</th>
              <th>Martes</th>
              <th>Miércoles</th>
              <th>Jueves</th>
              <th>Viernes</th>
              <th>Sábado</th>
            </tr>
          </thead>
          <tbody>
            {
              horariosManana.map((h) => (
                <tr>
                  <td class="actividad-name">
                    <strong>{h.actividad}</strong>
                  </td>
                  <td>{h.lunes}</td>
                  <td>{h.martes}</td>
                  <td>{h.miercoles}</td>
                  <td>{h.jueves}</td>
                  <td>{h.viernes}</td>
                  <td>{h.sabado}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <div class="notas">
        <p>*Servicio de telebaile y clases particulares.</p>
        <p>
          *Cursos especiales para novios, defensa personal y cenas con baile.
        </p>
      </div>
    </div>
  </section>
</Layout>
