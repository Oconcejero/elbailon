---
import Layout from "../layout/layout.astro";

const actividades = [
  {
    title: "Bailes de salón",
    desc: "Aprende Salsa en línea y cubana con los mejores pasos.",
    img: "/elbailon/actividades/actividades_full/bailes-de-salon-400x284.jpg",
  },
  {
    title: "Latinos",
    desc: "Sensual, dominicana y moderna. ¡Fluye con el ritmo!",
    img: "/elbailon/actividades/actividades_full/latinos-400x284.jpg",
  },
  {
    title: "Funky hip-hop",
    desc: "El baile más conectado y suave llegado de Angola.",
    img: "/elbailon/actividades/actividades_full/funcky-400x284.jpg",
  },
  {
    title: "Ballet",
    desc: "Diversión en grupo asegurada con figuras dinámicas.",
    img: "/elbailon/actividades/actividades_full/ballet-400x284.jpg",
  },
  {
    title: "Puntas",
    desc: "Vals, Pasodoble, Tango... elegancia en la pista.",
    img: "/elbailon/actividades/actividades_full/puntas-400x284.jpg",
  },
  {
    title: "Contemporáneo",
    desc: "Conecta con tu feminidad y mejora tu flexibilidad.",
    img: "/elbailon/actividades/actividades_full/Baile-contemporáneo-400x284.jpg",
  },
  {
    title: "Predanza",
    desc: "Equilibrio cuerpo-mente para empezar el día con energía.",
    img: "/elbailon/actividades/actividades_full/pedraza-400x284.jpg",
  },
  {
    title: "Sevillanas",
    desc: "Fortalece tu core y mejora tu postura corporal.",
    img: "/elbailon/actividades/actividades_full/sevillanas-400x284.jpg",
  },
  {
    title: "Flamenco",
    desc: "Quema calorías divirtiéndote con ritmos latinos.",
    img: "/elbailon/actividades/actividades_full/flamenco-400x284.jpg",
  },
  {
    title: "Escuela Bolera",
    desc: "Quema calorías divirtiéndote con ritmos latinos.",
    img: "/elbailon/actividades/actividades_full/bollybwood-400x284.jpg",
  },
  {
    title: "Danza del vientre",
    desc: "Quema calorías divirtiéndote con ritmos latinos.",
    img: "/elbailon/actividades/actividades_full/danza-de-vientre-400x284.jpg",
  },
  {
    title: "Rock & Roll",
    desc: "Quema calorías divirtiéndote con ritmos latinos.",
    img: "/elbailon/actividades/actividades_full/rockandroll-400x284.jpg",
  },
  {
    title: "Tango",
    desc: "Quema calorías divirtiéndote con ritmos latinos.",
    img: "/elbailon/actividades/actividades_full/Monograficos-400x284.jpg",
  },
  {
    title: "Kizomba",
    desc: "Quema calorías divirtiéndote con ritmos latinos.",
    img: "/elbailon/actividades/actividades_full/kizomba-400x284.jpg",
  },
];
---

<Layout title="Actividades | El Bailón">
  <section class="actividades-hero">
    <h1>Nuestras Actividades</h1>
    <p>Encuentra tu estilo y empieza a bailar hoy mismo</p>
  </section>

  <section class="grid-actividades">
    <div class="container">
      <div class="cards-wrapper">
        {
          actividades.map((item) => (
            <div class="card">
              <div
                class="card-img"
                style={`background-image: url(${item.img});`}
              >
                <div class="overlay">
                  <h3>{item.title}</h3>
                </div>
              </div>
              <div class="card-content">
                <p>{item.desc}</p>
                <a href="/contacto" class="btn-saber-mas">
                  Me interesa
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
