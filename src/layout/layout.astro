---
import "../styles/global.css";
const { title = "Escuela de Danza El Bailón" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link rel="icon" type="image/x-icon" href={`${base}favicon.ico`} />
    <title>{title}</title>
  </head>
  <body>
    <header class="main-header">
      <div class="header-container">
        <a href={`${base}`} class="logo">
          <img src={`${base}EL_BAILON.png`} alt="Logo El Bailón" />
        </a>

        <button class="mobile-menu-toggle" aria-label="Abrir menú">
          <span class="bar"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </button>

        <nav class="nav-menu">
          <ul class="nav-links">
            <li><a href={`${base}`}>Inicio</a></li>
            <li><a href={`${base}actividades/`}>Actividades</a></li>
            <li><a href={`${base}horarios/`}>Horarios</a></li>
            <li><a href={`${base}fiestasyeventos/`}>Fiestas y Eventos</a></li>
            <li><a href={`${base}galeria/`}>Galería</a></li>
            <li>
              <a href={`${base}contacto/`} class="btn-contacto">Contacto</a>
            </li>
            <li class="social-li">
              <div class="social-links">
                <a
                  href="https://www.facebook.com/elbailon.escuela"
                  target="_blank"
                  aria-label="Facebook"
                >
                  <i class="fa-brands fa-facebook"></i>
                </a>
                <a
                  href="https://www.instagram.com/escuela_el_bailon/"
                  target="_blank"
                  aria-label="Instagram"
                >
                  <i class="fa-brands fa-instagram"></i>
                </a>
              </div>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>
  </body>

  <script>
    const menuToggle = document.querySelector(".mobile-menu-toggle");
    const navMenu = document.querySelector(".nav-menu");

    if (menuToggle && navMenu) {
      menuToggle.addEventListener("click", () => {
        navMenu.classList.toggle("active");
        menuToggle.classList.toggle("is-active");
      });
    }
  </script>
</html>
